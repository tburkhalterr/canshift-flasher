{
  "_comment": "Drift layout — WIP. Wheel angle, handbrake state and lateral-G aren't in the baseline signal catalog yet, so this ships with RPM + throttle + battery and stub gauges using placeholder signal names. Re-bind the placeholder signals in Studio to your steering / IMU / handbrake feeds.",
  "version": "1.0.0",
  "name": "Drift",
  "description": "WIP — placeholder layout (steering / handbrake / lateral-G signals not in catalog yet, edit in Studio)",
  "defaultPageId": "drift",
  "revLimitRpm": 8000,
  "topBar": {
    "height": 16,
    "bgColor": "#0D0D0D",
    "textColor": "#AAAAAA",
    "layout": [
      { "type": "statusDot", "signal": "any", "position": "left" },
      { "type": "label", "text": "DRIFT", "position": "left" },
      { "type": "themeToggle", "position": "right" }
    ]
  },
  "pages": [
    {
      "id": "drift",
      "backgroundImage": null,
      "backgroundColor": "#000000",
      "showTopBar": true,
      "widgets": [
