          "signal": "rpm",
          "layout": { "x": 0, "y": 0, "w": 160, "h": 112, "zOrder": 0 },
          "style": {
            "primaryColor": "#FF4444",
            "secondaryColor": "#2A2A2A",
            "warningColor": "#FF8800",
            "criticalColor": "#FF4444",
            "textColor": "#FFFFFF",
            "fontSize": 28
          },
          "config": {
            "type": "gauge",
            "displayStyle": "arc",
            "iconName": "rpm",
            "minValue": 0,
            "maxValue": 8500,
