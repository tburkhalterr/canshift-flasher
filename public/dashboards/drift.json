          "style": {
            "primaryColor": "#FB8C00",
            "secondaryColor": "#2A2A2A",
            "warningColor": "#FF8800",
            "criticalColor": "#FF4444",
            "textColor": "#FFFFFF",
            "fontSize": 22
          },
          "config": {
            "type": "gauge",
            "displayStyle": "arc",
            "iconName": "throttle",
            "minValue": 0,
            "maxValue": 100,
