{
  "_comment": "Minimal OBD-II Mode 01 profile — polled request/response. canFrameId is the standard response frame (0x7E8); the firmware Obd2Poller sends 0x7DF queries at intervalMs and decodes into these signals (see canshift-core/src/schemas/obd2.ts).",
  "_warning": "Most production ECUs respond on 0x7E8, but truck/HD-OBD and some EVs use 29-bit IDs. Verify with a CAN sniffer before relying on these for live data.",
  "version": "1.0.0",
  "protocol": "custom_v1.0",
  "canSpeedKbps": 500,
  "signals": [
    {
      "name": "rpm",
      "canFrameId": "0x7E8",
      "startByte": 3,
      "byteLength": 2,
      "bigEndian": true,
      "signed": false,
      "scale": 0.25,
      "offset": 0.0,
      "unit": "rpm",
      "min": 0,
      "max": 8000,
      "warningLevel": 6500,
      "dangerLevel": 7200,
      "timeoutMs": 2000,
      "polling": { "mode": 1, "pid": 12, "intervalMs": 200 }
    },
    {
      "name": "speed_kph",
      "canFrameId": "0x7E8",
      "startByte": 3,
      "byteLength": 1,
      "bigEndian": true,
      "signed": false,
      "scale": 1.0,
      "offset": 0.0,
      "unit": "km/h",
      "min": 0,
      "max": 255,
      "timeoutMs": 2000,
      "polling": { "mode": 1, "pid": 13, "intervalMs": 500 }
    },
    {
      "name": "throttle_pos",
      "canFrameId": "0x7E8",
      "startByte": 3,
      "byteLength": 1,
      "bigEndian": true,
      "signed": false,
      "scale": 0.392156862745098,
      "offset": 0.0,
      "unit": "%",
      "min": 0,
      "max": 100,
      "timeoutMs": 2000,
      "polling": { "mode": 1, "pid": 17, "intervalMs": 500 }
    },
    {
      "name": "coolant_temp_c",
      "canFrameId": "0x7E8",
      "startByte": 3,
      "byteLength": 1,
      "bigEndian": true,
      "signed": false,
      "scale": 1.0,
      "offset": -40.0,
      "unit": "°C",
      "min": -40,
      "max": 150,
      "warningLevel": 100,
      "dangerLevel": 115,
      "timeoutMs": 5000,
      "polling": { "mode": 1, "pid": 5, "intervalMs": 1000 }
    },
    {
      "name": "iat_c",
      "canFrameId": "0x7E8",
      "startByte": 3,
      "byteLength": 1,
      "bigEndian": true,
      "signed": false,
      "scale": 1.0,
      "offset": -40.0,
      "unit": "°C",
      "min": -40,
      "max": 100,
      "warningLevel": 50,
      "dangerLevel": 65,
      "timeoutMs": 5000,
      "polling": { "mode": 1, "pid": 15, "intervalMs": 1000 }
    },
    {
      "name": "battery_volts",
      "canFrameId": "0x7E8",
      "startByte": 3,
      "byteLength": 2,
      "bigEndian": true,
      "signed": false,
      "scale": 0.001,
      "offset": 0.0,
      "unit": "V",
      "min": 8,
      "max": 18,
      "warningLevel": 12.0,
      "dangerLevel": 11.5,
      "highWarningLevel": 15.0,
      "highDangerLevel": 16.0,
