{
  "name": "canshift-flasher",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "USB firmware flasher for CANShift dash. Chromium-only Web Serial single-page app.",
  "scripts": {
    "dev": "vite",
    "docs:dev": "vitepress dev docs --port 5181",
    "build": "npm run build:flasher && npm run build:docs && node scripts/copy-docs.mjs",
    "build:flasher": "tsc -b && vite build && node scripts/inject-sw-version.mjs",
    "build:docs": "vitepress build docs",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "sync-brand": "node scripts/sync-brand-assets.mjs",
    "build-profiles": "node scripts/build-profiles.mjs",
    "verify-profiles": "node scripts/build-profiles.mjs --check"
  },
  "dependencies": {
    "esptool-js": "0.6.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.60.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/w3c-web-serial": "1.0.8",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.7",
    "autoprefixer": "10.5.0",
    "eslint": "9.39.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.19",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vite": "8.0.14",
    "vitepress": "^1.6.4",
    "vitest": "4.1.7"
  }
}
