    "@types/w3c-web-serial": "1.0.8",
    "@vitejs/plugin-react": "6.0.2",
    "autoprefixer": "10.5.0",
    "eslint": "10.4.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.19",
